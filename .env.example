# LLM Configuration
LLM_PROVIDER=openai           # openai | deepseek | ollama
LLM_MODEL=gpt-4o              # gpt-4o | gpt-4-turbo | deepseek-chat | llama3
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=              # Optional: custom endpoint (e.g. DeepSeek)

# Browser Configuration
HEADLESS=false               # true = no GUI
BROWSER_TIMEOUT=30000        # ms
SLOW_MO=0                    # slow motion delay in ms (for debugging)

# Agent Configuration
MAX_STEPS=20                 # maximum steps before giving up
SCREENSHOT_MODE=true         # use screenshot as observation
DOM_MODE=true                # also use DOM as observation

# Logging
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
SAVE_SCREENSHOTS=false       # save screenshots to disk
SCREENSHOT_DIR=./screenshots
